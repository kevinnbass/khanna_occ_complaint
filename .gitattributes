# Auto-generated by build_public_release.py — do not hand-edit.
# Without these, a reviewer cloning on Windows with the default
# core.autocrlf=true would get CRLF line endings injected into
# the SHA256 manifest, breaking the OpenTimestamps proof.

# Catch-all: every text file lives at LF on every platform.
* text=auto eol=lf

# The SHA256 manifest is byte-stable; never let git transform it.
99_SHA256SUMS.txt -text

